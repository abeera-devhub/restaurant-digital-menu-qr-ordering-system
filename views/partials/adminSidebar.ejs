<%# views/partials/adminSidebar.ejs %>
<%# Reusable admin sidebar. Requires: currentPage variable. %>

<aside class="admin-sidebar" id="adminSidebar" role="navigation" aria-label="Admin Navigation">

  <%# Brand %>
  <div class="sidebar-brand">
    <div class="sidebar-brand-icon" aria-hidden="true">
      <svg width="28" height="28" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="36" height="36" rx="10" fill="#8B2500"/>
        <path d="M10 8v4c0 3.31 2.69 6 6 6v8h4V18c3.31 0 6-2.69 6-6V8h-2v4c0 2.21-1.79 4-4 4h-4c-2.21 0-4-1.79-4-4V8h-2z" fill="#FFFFFF"/>
        <circle cx="18" cy="27" r="2" fill="#FFFFFF"/>
      </svg>
    </div>
    <span class="sidebar-brand-name">BISTRO MODERN</span>
  </div>

  <%# Navigation Links %>
  <nav class="sidebar-nav" aria-label="Main menu">
    <ul class="sidebar-nav-list" role="list">

      <li class="sidebar-nav-item">
        <a href="/admin/dashboard"
           class="sidebar-nav-link <%= currentPage === 'dashboard' ? 'active' : '' %>"
           aria-current="<%= currentPage === 'dashboard' ? 'page' : 'false' %>">
          <span class="nav-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
              <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
            </svg>
          </span>
          <span class="nav-label">Dashboard</span>
        </a>
      </li>

      <li class="sidebar-nav-item">
        <a href="/admin/categories"
           class="sidebar-nav-link <%= currentPage === 'categories' ? 'active' : '' %>"
           aria-current="<%= currentPage === 'categories' ? 'page' : 'false' %>">
          <span class="nav-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/>
              <line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/>
              <line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>
            </svg>
          </span>
          <span class="nav-label">Categories</span>
        </a>
      </li>

      <li class="sidebar-nav-item">
        <a href="/admin/menu-items"
           class="sidebar-nav-link <%= currentPage === 'menuItems' ? 'active' : '' %>"
           aria-current="<%= currentPage === 'menuItems' ? 'page' : 'false' %>">
          <span class="nav-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 2h18v6H3z"/><path d="M3 10h18v6H3z"/><path d="M3 18h18v4H3z"/>
            </svg>
          </span>
          <span class="nav-label">Menu Items</span>
        </a>
      </li>

      <li class="sidebar-nav-item">
        <a href="/admin/orders"
           class="sidebar-nav-link <%= currentPage === 'orders' ? 'active' : '' %>"
           aria-current="<%= currentPage === 'orders' ? 'page' : 'false' %>">
          <span class="nav-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
              <rect x="9" y="3" width="6" height="4" rx="2"/>
              <line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/>
            </svg>
          </span>
          <span class="nav-label">Orders</span>
        </a>
      </li>

      <li class="sidebar-nav-item">
        <a href="/admin/bill-requests"
           class="sidebar-nav-link <%= currentPage === 'billRequests' ? 'active' : '' %>"
           aria-current="<%= currentPage === 'billRequests' ? 'page' : 'false' %>">
          <span class="nav-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="5" width="20" height="14" rx="2"/>
              <line x1="2" y1="10" x2="22" y2="10"/>
            </svg>
          </span>
          <span class="nav-label">Bill Requests</span>
        </a>
      </li>

      <li class="sidebar-nav-item">
        <a href="/admin/staff"
           class="sidebar-nav-link <%= currentPage === 'staff' ? 'active' : '' %>"
           aria-current="<%= currentPage === 'staff' ? 'page' : 'false' %>">
          <span class="nav-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </span>
          <span class="nav-label">Staff</span>
        </a>
      </li>

      <li class="sidebar-nav-item">
        <a href="/admin/settings"
           class="sidebar-nav-link <%= currentPage === 'settings' ? 'active' : '' %>"
           aria-current="<%= currentPage === 'settings' ? 'page' : 'false' %>">
          <span class="nav-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="3"/>
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
            </svg>
          </span>
          <span class="nav-label">Settings</span>
        </a>
      </li>

    </ul>
  </nav>

  <%# Logout %>
  <div class="sidebar-footer">
    <a href="/auth/admin/logout" class="sidebar-logout-btn" aria-label="Logout">
      <span class="nav-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
          <polyline points="16 17 21 12 16 7"/>
          <line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
      </span>
      <span class="nav-label">Logout</span>
    </a>
  </div>

</aside>

<div class="sidebar-overlay" id="sidebarOverlay" aria-hidden="true"></div>