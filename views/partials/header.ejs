<%# views/partials/header.ejs %>
<%# Shared head block. extraCSS variable must be set before including this. %>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content="Bistro Modern — Restaurant Digital Menu & QR Ordering System" />

<title><%= typeof title !== 'undefined' ? title + ' | Bistro Modern' : 'Bistro Modern' %></title>

<link rel="stylesheet" href="/css/global.css" />

<% if (typeof extraCSS !== 'undefined' && extraCSS) { %>
  <link rel="stylesheet" href="<%= extraCSS %>" />
<% } %>